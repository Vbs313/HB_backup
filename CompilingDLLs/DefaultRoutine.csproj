<?xml version="1.0" encoding="utf-8"?>
<!-- DefaultRoutine 项目文件 -->
<!-- 这是 Hearthbuddy 炉石传说自动化工具的默认例程项目 -->
<Project ToolsVersion="12.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- 项目基本属性配置 -->
  <PropertyGroup>
    <!-- 默认配置为 Debug -->
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <!-- 默认平台为 x86 -->
    <Platform Condition=" '$(Platform)' == '' ">x86</Platform>
    <!-- 项目唯一标识符 -->
    <ProjectGuid>{77540557-1C8F-4388-8314-A0F9343870BC}</ProjectGuid>
    <!-- 输出类型为类库 -->
    <OutputType>Library</OutputType>
    <!-- 包含标准库 -->
    <NoStandardLibraries>false</NoStandardLibraries>
    <!-- 程序集名称 -->
    <AssemblyName>DefaultRoutine</AssemblyName>
    <!-- 根命名空间 -->
    <RootNamespace>HREngine.Bots</RootNamespace>
    <!-- 目标 .NET 框架版本 -->
    <TargetFrameworkVersion>v4.8.1</TargetFrameworkVersion>
    <TargetFrameworkProfile />
    <!-- 文件对齐大小 -->
    <FileAlignment>512</FileAlignment>
    <!-- 不生成 AssemblyInfo 文件 -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>
  <!-- Debug 配置设置 -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x86' ">
    <!-- 生成调试符号 -->
    <DebugSymbols>false</DebugSymbols>
    <!-- 不生成调试信息 -->
    <DebugType>none</DebugType>
    <!-- 不优化代码 -->
    <Optimize>false</Optimize>
    <!-- 输出路径（Debug 输出到 CompilingDLLs 目录） -->
    <OutputPath>..\CompiledAssemblies\</OutputPath>
    <!-- 中间输出路径 -->
    <BaseIntermediateOutputPath>..\obj\DefaultRoutine\</BaseIntermediateOutputPath>
    <!-- 定义常量 -->
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <!-- 错误报告方式 -->
    <ErrorReport>prompt</ErrorReport>
    <!-- 警告级别 -->
    <WarningLevel>4</WarningLevel>
    <!-- 目标平台 -->
    <PlatformTarget>x86</PlatformTarget>
    <!-- 不首选 32 位 -->
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>
  <!-- Release 配置设置 -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|x86' ">
    <!-- 不生成调试信息 -->
    <DebugType>none</DebugType>
    <!-- 优化代码 -->
    <Optimize>true</Optimize>
    <!-- 输出路径 -->
    <OutputPath>..\CompiledAssemblies\</OutputPath>
    <!-- 中间输出路径 -->
    <BaseIntermediateOutputPath>..\obj\DefaultRoutine\</BaseIntermediateOutputPath>
    <!-- 定义常量 -->
    <DefineConstants>TRACE</DefineConstants>
    <!-- 错误报告方式 -->
    <ErrorReport>prompt</ErrorReport>
    <!-- 警告级别 -->
    <WarningLevel>4</WarningLevel>
    <!-- 目标平台 -->
    <PlatformTarget>x86</PlatformTarget>
    <!-- 不首选 32 位 -->
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>
  <!-- 启动对象配置 -->
  <PropertyGroup>
    <StartupObject>
    </StartupObject>
  </PropertyGroup>
  <!-- 项目引用默认设置 -->
  <ItemDefinitionGroup>
    <Reference>
      <!-- 不将引用复制到输出目录 -->
      <Private>False</Private>
    </Reference>
  </ItemDefinitionGroup>
  <!-- 项目引用 -->
  <ItemGroup>
    <!-- DefaultBot 引用 -->
    <!-- GreyMagic 引用 -->
    <Reference Include="GreyMagic, Version=1.0.121.0, Culture=neutral, PublicKeyToken=260525fa2b0e778a, processorArchitecture=x86">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\lib\GreyMagic.dll</HintPath>
    </Reference>
    <!-- Hearthbuddy 引用 -->
    <Reference Include="Hearthbuddy, Version=0.0.0.0, Culture=neutral, processorArchitecture=x86">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\Hearthbuddy.exe</HintPath>
    </Reference>
    <!-- IronPython 相关引用 -->
    <Reference Include="IronPython, Version=2.7.0.40, Culture=neutral, PublicKeyToken=7f709c5b713576e1, processorArchitecture=MSIL">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\lib\IronPython.dll</HintPath>
    </Reference>
    <Reference Include="IronPython.Modules, Version=2.7.0.40, Culture=neutral, PublicKeyToken=7f709c5b713576e1, processorArchitecture=MSIL">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\lib\IronPython.Modules.dll</HintPath>
    </Reference>
    <!-- 日志库引用 -->
    <Reference Include="log4net, Version=1.2.11.0, Culture=neutral, PublicKeyToken=669e0ddf0bb1aa2a, processorArchitecture=MSIL">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\lib\log4net.dll</HintPath>
    </Reference>
    <!-- C# 支持 -->
    <Reference Include="Microsoft.CSharp" />
    <!-- 动态语言运行时引用 -->
    <Reference Include="Microsoft.Dynamic, Version=1.1.0.20, Culture=neutral, PublicKeyToken=7f709c5b713576e1, processorArchitecture=MSIL">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\lib\Microsoft.Dynamic.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Scripting, Version=1.1.0.20, Culture=neutral, PublicKeyToken=7f709c5b713576e1, processorArchitecture=MSIL">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\lib\Microsoft.Scripting.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Scripting.Metadata, Version=1.1.0.20, Culture=neutral, PublicKeyToken=7f709c5b713576e1, processorArchitecture=MSIL">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\lib\Microsoft.Scripting.Metadata.dll</HintPath>
    </Reference>
    <!-- WPF 相关引用 -->
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <!-- 系统库引用 -->
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Data" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="System.Xaml" />
    <Reference Include="System.Xml" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="WindowsBase" />
  </ItemGroup>
  <!-- 编译文件 -->
  <ItemGroup>
    <!-- 注释掉的旧编译配置（排除测试文件） -->
    <!-- <Compile Include="Routines\DefaultRoutine\**\*.cs" Exclude="Routines\DefaultRoutine\Silverfish\Test\**\*.cs" /> -->
    <!-- 包含所有 C# 文件进行编译 -->
    <Compile Include="..\Routines\DefaultRoutine\**\*.cs" />
  </ItemGroup>
  <!-- 其他文件（不参与编译但需要包含在项目中） -->
  <ItemGroup>
    <!-- 设置界面 XAML 文件 -->
    <None Include="..\Routines\DefaultRoutine\SettingsGui.xaml" />
    <!-- Silverfish 行为配置文件 -->
    <None Include="..\Routines\DefaultRoutine\Silverfish\behavior\**\*.txt" />
    <!-- 卡牌定义 XML 文件 -->
    <None Include="..\Routines\DefaultRoutine\Silverfish\data\CardDefs.xml" />
    <!-- HSReplay 数据 JSON 文件 -->
    <None Include="..\Routines\DefaultRoutine\Silverfish\Hsreplay\*.json" />
  </ItemGroup>
  <!-- 导入 C# 目标 -->
  <ItemGroup>
    <ProjectReference Include="DefaultBot.csproj">
      <Project>{12345678-1234-4567-8901-234567890123}</Project>
      <Name>DefaultBot</Name>
    </ProjectReference>
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>